# ── lcdp-attendance env vars ──
# Coolify injects these at runtime; this file documents what the app needs.
# Do NOT commit real secrets.

# Postgres connection string. In Coolify, set this to point at the internal
# Postgres service, e.g.  postgresql://lcdp:<pw>@postgres:5432/lcdp?schema=public
DATABASE_URL="postgresql://user:password@host:5432/lcdp?schema=public"

# NextAuth v5 — REQUIRED in production. Generate with `openssl rand -base64 32`.
AUTH_SECRET="change-me"

# Optional: set to the app's public URL so NextAuth builds correct callback URLs.
# Coolify will usually set this automatically; override if needed.
# AUTH_URL="https://attendance.example.com"

# Used only by `prisma db seed` the first time Gianca's admin account is created.
# Remove after the initial seed if you like.
ADMIN_PASSWORD="change-me-before-first-seed"
